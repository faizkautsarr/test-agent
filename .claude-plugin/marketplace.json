{
  "name": "test-agent",
  "owner": {
    "name": "faizkautsarr"
  },
  "plugins": [
    {
      "name": "count",
      "version": "1.0.0",
      "description": "Count the number of characters in a given string",
      "command": "count",
      "usage": "/count \"<string>\"",
      "examples": [
        {
          "input": "/count \"aaa\"",
          "output": "3"
        },
        {
          "input": "/count \"hello world\"",
          "output": "11"
        }
      ]
    }
  ]
}
